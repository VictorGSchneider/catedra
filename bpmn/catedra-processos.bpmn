<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_Catedra" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Claude AI" exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_Catedra">
    <bpmn:participant id="Pool_EntregaCorrecao" name="Entrega e Correção de Atividade" processRef="Process_EntregaCorrecao" />
    <bpmn:participant id="Pool_ModoFoco" name="Notificações Adaptativas (Modo Foco)" processRef="Process_ModoFoco" />
    <bpmn:participant id="Pool_FormacaoGrupo" name="Formação de Grupo de Trabalho" processRef="Process_FormacaoGrupo" />
  </bpmn:collaboration>
  <bpmn:process id="Process_EntregaCorrecao" name="Entrega e Correção de Atividade" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Process_EntregaCorrecao">
      <bpmn:lane id="Lane_Professor" name="Professor">
        <bpmn:flowNodeRef>Start_AtividadePronta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublicarAtividade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CorrigirEntrega</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublicarNota</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SistemaEC" name="Sistema">
        <bpmn:flowNodeRef>Task_NotificarTurma</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_DentroPrazo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarEntregue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarAtrasada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmitirEvento</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Estudante" name="Estudante">
        <bpmn:flowNodeRef>Task_EnviarEntrega</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConsultarNota</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Fim</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_AtividadePronta" name="Atividade pronta">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_PublicarAtividade" name="Publicar atividade (com prazo)">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_NotificarTurma" name="Notificar estudantes (cadência)">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_EnviarEntrega" name="Elaborar e enviar entrega">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gw_DentroPrazo" name="Dentro do prazo?">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RegistrarEntregue" name="Registrar como Entregue">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_RegistrarAtrasada" name="Registrar como Atrasada">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_CorrigirEntrega" name="Corrigir entrega">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_PublicarNota" name="Publicar nota">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_EmitirEvento" name="Emitir evento e notificar">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:userTask id="Task_ConsultarNota" name="Consultar nota e feedback">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_Fim" name="Fim">
      <bpmn:incoming>f12</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start_AtividadePronta" targetRef="Task_PublicarAtividade" />
    <bpmn:sequenceFlow id="f2" sourceRef="Task_PublicarAtividade" targetRef="Task_NotificarTurma" />
    <bpmn:sequenceFlow id="f3" sourceRef="Task_NotificarTurma" targetRef="Task_EnviarEntrega" />
    <bpmn:sequenceFlow id="f4" sourceRef="Task_EnviarEntrega" targetRef="Gw_DentroPrazo" />
    <bpmn:sequenceFlow id="f5" name="Sim" sourceRef="Gw_DentroPrazo" targetRef="Task_RegistrarEntregue" />
    <bpmn:sequenceFlow id="f6" name="Não" sourceRef="Gw_DentroPrazo" targetRef="Task_RegistrarAtrasada" />
    <bpmn:sequenceFlow id="f7" sourceRef="Task_RegistrarEntregue" targetRef="Task_CorrigirEntrega" />
    <bpmn:sequenceFlow id="f8" sourceRef="Task_RegistrarAtrasada" targetRef="Task_CorrigirEntrega" />
    <bpmn:sequenceFlow id="f9" sourceRef="Task_CorrigirEntrega" targetRef="Task_PublicarNota" />
    <bpmn:sequenceFlow id="f10" sourceRef="Task_PublicarNota" targetRef="Task_EmitirEvento" />
    <bpmn:sequenceFlow id="f11" sourceRef="Task_EmitirEvento" targetRef="Task_ConsultarNota" />
    <bpmn:sequenceFlow id="f12" sourceRef="Task_ConsultarNota" targetRef="End_Fim" />
    <bpmn:textAnnotation id="Ann_RN07">
      <bpmn:text>Cadência por estudante (RN07 / Modo Foco)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_RN03">
      <bpmn:text>Prazo aceita ou bloqueia atraso (RN03)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_RN05">
      <bpmn:text>Nota só visível após publicação (RN05)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Ann_RN07" sourceRef="Task_NotificarTurma" targetRef="Ann_RN07" />
    <bpmn:association id="Assoc_Ann_RN03" sourceRef="Gw_DentroPrazo" targetRef="Ann_RN03" />
    <bpmn:association id="Assoc_Ann_RN05" sourceRef="Task_PublicarNota" targetRef="Ann_RN05" />
  </bpmn:process>
  <bpmn:process id="Process_ModoFoco" name="Notificações Adaptativas (Modo Foco)" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Process_ModoFoco">
      <bpmn:lane id="Lane_EstudanteMF" name="Estudante">
        <bpmn:flowNodeRef>Start_AjustarNotif</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AbrirPref</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelecionarCadencia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Aplicada</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SistemaMF" name="Sistema">
        <bpmn:flowNodeRef>Task_ValidarPref</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_PrefValida</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SalvarPref</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Invalida</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AplicarMotor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmarAluno</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_AjustarNotif" name="Quer ajustar notificações">
      <bpmn:outgoing>g1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_AbrirPref" name="Abrir preferências de notificação">
      <bpmn:incoming>g1</bpmn:incoming>
      <bpmn:outgoing>g2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SelecionarCadencia" name="Selecionar cadência de notificação">
      <bpmn:incoming>g2</bpmn:incoming>
      <bpmn:outgoing>g3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ValidarPref" name="Validar preferências">
      <bpmn:incoming>g3</bpmn:incoming>
      <bpmn:outgoing>g4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_PrefValida" name="Configuração válida?">
      <bpmn:incoming>g4</bpmn:incoming>
      <bpmn:outgoing>g5</bpmn:outgoing>
      <bpmn:outgoing>g6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_SalvarPref" name="Salvar preferências (Modo Foco)">
      <bpmn:incoming>g5</bpmn:incoming>
      <bpmn:outgoing>g7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Invalida" name="Configuração inválida">
      <bpmn:incoming>g6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_AplicarMotor" name="Aplicar ao motor de eventos">
      <bpmn:incoming>g7</bpmn:incoming>
      <bpmn:outgoing>g8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_ConfirmarAluno" name="Confirmar ao estudante">
      <bpmn:incoming>g8</bpmn:incoming>
      <bpmn:outgoing>g9</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_Aplicada" name="Preferências aplicadas">
      <bpmn:incoming>g9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="g1" sourceRef="Start_AjustarNotif" targetRef="Task_AbrirPref" />
    <bpmn:sequenceFlow id="g2" sourceRef="Task_AbrirPref" targetRef="Task_SelecionarCadencia" />
    <bpmn:sequenceFlow id="g3" sourceRef="Task_SelecionarCadencia" targetRef="Task_ValidarPref" />
    <bpmn:sequenceFlow id="g4" sourceRef="Task_ValidarPref" targetRef="Gw_PrefValida" />
    <bpmn:sequenceFlow id="g5" name="Sim" sourceRef="Gw_PrefValida" targetRef="Task_SalvarPref" />
    <bpmn:sequenceFlow id="g6" name="Não" sourceRef="Gw_PrefValida" targetRef="End_Invalida" />
    <bpmn:sequenceFlow id="g7" sourceRef="Task_SalvarPref" targetRef="Task_AplicarMotor" />
    <bpmn:sequenceFlow id="g8" sourceRef="Task_AplicarMotor" targetRef="Task_ConfirmarAluno" />
    <bpmn:sequenceFlow id="g9" sourceRef="Task_ConfirmarAluno" targetRef="End_Aplicada" />
    <bpmn:textAnnotation id="Ann_Cadencia">
      <bpmn:text>Cadências configuráveis (RN07)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_Inovacao">
      <bpmn:text>Funcionalidade Inovadora: Modo Foco</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Ann_Cadencia" sourceRef="Task_SelecionarCadencia" targetRef="Ann_Cadencia" />
    <bpmn:association id="Assoc_Ann_Inovacao" sourceRef="Task_AplicarMotor" targetRef="Ann_Inovacao" />
  </bpmn:process>
  <bpmn:process id="Process_FormacaoGrupo" name="Formação de Grupo de Trabalho" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Process_FormacaoGrupo">
      <bpmn:lane id="Lane_EstudanteGR" name="Estudante">
        <bpmn:flowNodeRef>Start_GrupoDisp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CriarEntrar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Aberto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Pronto</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SistemaGR" name="Sistema">
        <bpmn:flowNodeRef>Task_ValidarRegras</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_FormacaoOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarMembro</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Recusada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotificarMembros</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Fechado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TravarGrupo</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_GrupoDisp" name="Atividade em grupo disponível">
      <bpmn:outgoing>h1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_CriarEntrar" name="Criar grupo ou entrar em grupo existente">
      <bpmn:incoming>h1</bpmn:incoming>
      <bpmn:outgoing>h2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ValidarRegras" name="Validar regras (tamanho, 1 grupo por atividade)">
      <bpmn:incoming>h2</bpmn:incoming>
      <bpmn:outgoing>h3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gw_FormacaoOk" name="Formação permitida?">
      <bpmn:incoming>h3</bpmn:incoming>
      <bpmn:outgoing>h4</bpmn:outgoing>
      <bpmn:outgoing>h5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RegistrarMembro" name="Registrar participação no grupo">
      <bpmn:incoming>h4</bpmn:incoming>
      <bpmn:outgoing>h6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Recusada" name="Formação recusada">
      <bpmn:incoming>h5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Task_NotificarMembros" name="Notificar membros do grupo">
      <bpmn:incoming>h6</bpmn:incoming>
      <bpmn:outgoing>h7</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gw_Fechado" name="Grupo completo ou prazo encerrado?">
      <bpmn:incoming>h7</bpmn:incoming>
      <bpmn:outgoing>h8</bpmn:outgoing>
      <bpmn:outgoing>h9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_TravarGrupo" name="Travar grupo e habilitar entrega coletiva">
      <bpmn:incoming>h9</bpmn:incoming>
      <bpmn:outgoing>h10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Aberto" name="Grupo aberto (aguardando prazo)">
      <bpmn:incoming>h8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Pronto" name="Grupo pronto para entrega">
      <bpmn:incoming>h10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="h1" sourceRef="Start_GrupoDisp" targetRef="Task_CriarEntrar" />
    <bpmn:sequenceFlow id="h2" sourceRef="Task_CriarEntrar" targetRef="Task_ValidarRegras" />
    <bpmn:sequenceFlow id="h3" sourceRef="Task_ValidarRegras" targetRef="Gw_FormacaoOk" />
    <bpmn:sequenceFlow id="h4" name="Sim" sourceRef="Gw_FormacaoOk" targetRef="Task_RegistrarMembro" />
    <bpmn:sequenceFlow id="h5" name="Não" sourceRef="Gw_FormacaoOk" targetRef="End_Recusada" />
    <bpmn:sequenceFlow id="h6" sourceRef="Task_RegistrarMembro" targetRef="Task_NotificarMembros" />
    <bpmn:sequenceFlow id="h7" sourceRef="Task_NotificarMembros" targetRef="Gw_Fechado" />
    <bpmn:sequenceFlow id="h8" name="Não" sourceRef="Gw_Fechado" targetRef="End_Aberto" />
    <bpmn:sequenceFlow id="h9" name="Sim" sourceRef="Gw_Fechado" targetRef="Task_TravarGrupo" />
    <bpmn:sequenceFlow id="h10" sourceRef="Task_TravarGrupo" targetRef="End_Pronto" />
    <bpmn:textAnnotation id="Ann_RN09">
      <bpmn:text>Tamanho e 1 grupo por atividade (RN09)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Ann_RN10">
      <bpmn:text>Entrega e nota por grupo (RN10)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Ann_RN09" sourceRef="Task_ValidarRegras" targetRef="Ann_RN09" />
    <bpmn:association id="Assoc_Ann_RN10" sourceRef="Task_TravarGrupo" targetRef="Ann_RN10" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_Catedra">
      <bpmndi:BPMNShape id="Pool_EntregaCorrecao_di" bpmnElement="Pool_EntregaCorrecao" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1916.0" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Pool_ModoFoco_di" bpmnElement="Pool_ModoFoco" isHorizontal="true">
        <dc:Bounds x="160" y="840" width="1916.0" height="380" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Pool_FormacaoGrupo_di" bpmnElement="Pool_FormacaoGrupo" isHorizontal="true">
        <dc:Bounds x="160" y="1260" width="1916.0" height="380" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Professor_di" bpmnElement="Lane_Professor" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1886.0" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SistemaEC_di" bpmnElement="Lane_SistemaEC" isHorizontal="true">
        <dc:Bounds x="190" y="230" width="1886.0" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Estudante_di" bpmnElement="Lane_Estudante" isHorizontal="true">
        <dc:Bounds x="190" y="490" width="1886.0" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_EstudanteMF_di" bpmnElement="Lane_EstudanteMF" isHorizontal="true">
        <dc:Bounds x="190" y="840" width="1886.0" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SistemaMF_di" bpmnElement="Lane_SistemaMF" isHorizontal="true">
        <dc:Bounds x="190" y="990" width="1886.0" height="230" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_EstudanteGR_di" bpmnElement="Lane_EstudanteGR" isHorizontal="true">
        <dc:Bounds x="190" y="1260" width="1886.0" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_SistemaGR_di" bpmnElement="Lane_SistemaGR" isHorizontal="true">
        <dc:Bounds x="190" y="1410" width="1886.0" height="230" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_AtividadePronta_di" bpmnElement="Start_AtividadePronta">
        <dc:Bounds x="280" y="137" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="253" y="177" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublicarAtividade_di" bpmnElement="Task_PublicarAtividade" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="450" y="115" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotificarTurma_di" bpmnElement="Task_NotificarTurma" bioc:stroke="#b58900" bioc:fill="#fff2cc" color:background-color="#fff2cc" color:border-color="#b58900">
        <dc:Bounds x="620" y="320" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnviarEntrega_di" bpmnElement="Task_EnviarEntrega" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="790" y="525" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_DentroPrazo_di" bpmnElement="Gw_DentroPrazo" isMarkerVisible="true">
        <dc:Bounds x="960" y="335" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="940" y="389" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RegistrarEntregue_di" bpmnElement="Task_RegistrarEntregue" bioc:stroke="#5b176d" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#5b176d">
        <dc:Bounds x="1130" y="260" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RegistrarAtrasada_di" bpmnElement="Task_RegistrarAtrasada" bioc:stroke="#5b176d" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#5b176d">
